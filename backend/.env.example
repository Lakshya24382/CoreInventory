## Server
NODE_ENV=development
PORT=4000

## Database (use either DATABASE_URL OR the DB_* values)
# DATABASE_URL=postgres://postgres:YOUR_PASSWORD@localhost:5432/coreinventory
DB_HOST=localhost
DB_PORT=5432
DB_NAME=coreinventory
DB_USER=postgres
DB_PASSWORD=YOUR_PASSWORD
# DB_SSL=false

## Auth
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
JWT_EXPIRES_IN=8h

## OTP
OTP_TTL_MINUTES=15

## Email (optional; required only for signup confirmation / OTP email)
EMAIL_ENABLED=true
SMTP_SERVICE=gmail
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM=your_email@gmail.com

